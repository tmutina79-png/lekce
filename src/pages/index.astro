---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');
const sorted = docs.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const base = import.meta.env.BASE_URL;
---

<MainLayout title="Materiály">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Vítej na Studijním portálu 🎓</h1>

  <ul class="list-none p-0 m-0 space-y-2">
    {sorted.map((doc) => (
      <li>
        <a href={`${base}docs/${doc.id}`} class="text-indigo-600 hover:text-indigo-800 hover:underline transition-colors">
          {doc.data.title}
        </a>
      </li>
    ))}
  </ul>
</MainLayout>
